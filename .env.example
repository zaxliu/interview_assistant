# AI Configuration
VITE_AI_API_KEY=your_key
VITE_AI_MODEL=gpt-4

# AI API Base URL (for local dev - used by Vite proxy)
# In Docker, use AI_API_BASE_URL environment variable
VITE_AI_BASE_URL=https://api.openai.com

# Feishu Configuration (CORS proxy built-in)
VITE_FEISHU_APP_ID=cli_xxx
VITE_FEISHU_APP_SECRET=xxx
