# AI Configuration
VITE_AI_API_KEY=your_key
VITE_AI_BASE_URL=https://api.openai.com/v1
VITE_AI_MODEL=gpt-4

# Notion Configuration
VITE_NOTION_API_KEY=secret_xxx
VITE_NOTION_DATABASE_ID=xxx-xxx-xxx

# Feishu Configuration
VITE_FEISHU_APP_ID=cli_xxx
VITE_FEISHU_APP_SECRET=xxx

# CORS Proxy (optional - for Feishu API access from browser)
# Example: https://cors-anywhere.herokuapp.com
# Or run your own: npx local-cors-proxy --proxyUrl https://open.feishu.cn
VITE_CORS_PROXY=
