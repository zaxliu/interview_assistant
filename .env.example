# AI Configuration
VITE_AI_API_KEY=your_key
VITE_AI_MODEL=gpt-4

# AI API Base URL (must include the OpenAI-compatible API prefix, usually /v1)
VITE_AI_BASE_URL=https://api.openai.com/v1/

# Wintalent proxy base URL (for interview link one-click resume import)
VITE_WINTALENT_PROXY_URL=http://127.0.0.1:8787

# Docker-only override (nginx container -> wintalent proxy target)
# DOCKER_WINTALENT_PROXY_URL=http://wintalent-proxy:8787

# Metrics service base URL
VITE_METRICS_PROXY_URL=http://127.0.0.1:8788

# Docker-only override (nginx container -> metrics service target)
# DOCKER_METRICS_PROXY_URL=http://metrics:8788

# Production-only nginx HTTPS settings
# NGINX_SERVER_NAME=interview.example.com
# NGINX_CERT_DIR=/path/on/server/that/contains/server.crt-and-server.key

# Metrics admin auth
METRICS_SESSION_SECRET=replace-with-a-long-random-string
METRICS_ADMIN_FEISHU_USER_IDS=
# Optional explicit app credentials for metrics admin auth; defaults to VITE_FEISHU_* when omitted
# METRICS_FEISHU_APP_ID=cli_xxx
# METRICS_FEISHU_APP_SECRET=xxx

# Feishu Configuration (CORS proxy built-in)
VITE_FEISHU_APP_ID=cli_xxx
VITE_FEISHU_APP_SECRET=xxx
